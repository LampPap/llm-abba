python main-ts-classification.py \
--model_name "llama2-7B" \
--data_name 'mitbih' \
--batch_size=4 \
--lr=4e-4 \
--lora_r=${lora_r} \
--weight_decay=0.00001 \
--epochs=100 \
--ABBA_tol=${ABBA_tol} \
--ABBA_init=${ABBA_init} \
--ABBA_alpha=${ABBA_alpha} \
--ABBA_scl=1 \
--MAX_LENGTH 256

